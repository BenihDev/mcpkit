{
  "name": "@fanioz/mcpkit",
  "version": "1.0.0",
  "description": "Generate ready-to-use MCP servers from OpenAPI specs, databases, or YAML descriptions",
  "bin": {
    "mcpkit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --define:import.meta.url=__filename --define:import.meta.dirname=__dirname --external:better-sqlite3",
    "dev": "node --import tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scaffold",
    "generator",
    "openapi",
    "sqlite",
    "ai",
    "claude",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenihDev/mcpkit.git"
  },
  "homepage": "https://github.com/BenihDev/mcpkit#readme",
  "bugs": {
    "url": "https://github.com/BenihDev/mcpkit/issues"
  },
  "author": "fanioz <fanio.zilla@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
